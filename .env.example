# NFG client Supabase (project siabytqhreilqhngptyz) — the live data source.
# Injected server-side by the Vite proxy (/nfg). Never shipped to the browser.
VITE_NFG_SUPABASE_URL=https://siabytqhreilqhngptyz.supabase.co
VITE_NFG_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Before going live (client-facing) ────────────────────────────
# This dev setup uses the service key server-side via the proxy (fine for
# internal/staging). For production exposure either:
#   1. Enable Row Level Security on gyms / members / inbox_messages and use a
#      per-solution anon key, OR
#   2. Give NFG its own read-only Supabase project / a dedicated read role.
# Keep the fetch path proxied — never move the key into client-visible JS.
